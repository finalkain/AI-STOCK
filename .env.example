# Discord Bot (DM 전송용)
#
# [1회 세팅 — 5분]
#   1. https://discord.com/developers/applications 접속
#   2. "New Application" → 이름 아무거나 (예: AI_STOCK_BRIEFING)
#   3. 좌측 메뉴 "Bot" → "Add Bot" → "Yes, do it!"
#   4. "TOKEN" 섹션 "Reset Token" 또는 "Copy" → 아래 DISCORD_BOT_TOKEN 에 붙여넣기
#   5. Privileged Gateway Intents 섹션 → "MESSAGE CONTENT INTENT" 체크(권장)
#
# [봇이 DM 을 보낼 수 있게 하기]
#   방법 A (추천): 본인이 혼자 있는 서버 아무거나 만들어서 봇 초대
#     - 좌측 "OAuth2" → "URL Generator" → scopes: "bot" 체크
#     - Bot Permissions: "Send Messages" 만 체크
#     - 생성된 URL 접속 → 본인 서버 선택 → 초대
#   방법 B: 봇을 아무 공용 서버에 넣은 뒤, 본인이 봇에게 DM 한 번 먼저 보내기
#
# [본인의 Discord USER ID 찾기]
#   1. Discord 앱 설정 → 고급 → 개발자 모드 ON
#   2. 본인 프로필 우클릭 → "사용자 ID 복사"
#   3. 아래 DISCORD_USER_ID 에 붙여넣기 (숫자만)

DISCORD_BOT_TOKEN=MTxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DISCORD_USER_ID=000000000000000000

# (옵션) 향후 Claude API 해설 강화 시 사용
# ANTHROPIC_API_KEY=sk-ant-xxx

# 키움 REST API (실값은 .env 파일에 — 절대 여기 적지 마세요)
#
# [발급 절차]
#   1. https://openapi.kiwoom.com 접속 → 로그인
#   2. 마이페이지 → "앱 키" 발급 (APP KEY + SECRET KEY 한 쌍)
#   3. 실전투자 / 모의투자 별도 발급됨 (KIWOOM_IS_MOCK 으로 구분)
#
# [계좌번호]
#   - 영웅문 → 계좌 → "내 계좌" 8자리 (위탁계좌 본번호)
#   - 상품코드(2자리)는 코드에서 자동 부착됨
#
# [보안]
#   - 키를 노출했다면 즉시 폐기·재발급
#   - .env 만 .gitignore 됨 — .env.example 에는 placeholder 만!

KIWOOM_APP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIWOOM_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIWOOM_ACCOUNT_NO=00000000
KIWOOM_IS_MOCK=false   # true면 모의투자, false면 실전